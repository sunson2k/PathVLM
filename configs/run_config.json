{
  "_choices": {
    "model.resnet_source": ["torchvision", "huggingface_local"],
    "model.resnet_freeze_mode": ["none", "early", "all"],
    "model.dnn_normalization": ["batchnorm", "layernorm", "none"],
    "model.multimodal_model": ["concat", "cross_attention", "gmu"]
